# ---- Stage 1: Install + Build ----
FROM node:24-alpine AS build

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.32.1

# Copy workspace config and lockfile
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml turbo.json ./
COPY types.d.ts ./

# Copy all package.json files for dependency resolution
COPY apps/web/package.json apps/web/
COPY apps/server/package.json apps/server/
COPY packages/client/package.json packages/client/
COPY packages/store/package.json packages/store/
COPY packages/crypto/package.json packages/crypto/
COPY packages/schema/package.json packages/schema/
COPY packages/util/package.json packages/util/
COPY packages/ui/package.json packages/ui/
COPY packages/db/package.json packages/db/
COPY packages/typescript-config/package.json packages/typescript-config/
COPY packages/types/package.json packages/types/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy all source code
COPY apps/web/ apps/web/
COPY apps/server/ apps/server/
COPY packages/ packages/

# Build arg for the server URL
ARG VITE_SERVER_URL="/trpc"
ENV VITE_SERVER_URL=${VITE_SERVER_URL}

# Generate DB types (needed by server types which web imports)
RUN cd packages/db && npx drizzle-kit generate || true

# Build the web app (turborepo handles dependency order)
RUN pnpm --filter web build

# ---- Stage 2: Serve with Caddy ----
FROM caddy:2-alpine AS production

# Copy built static files
COPY --from=build /app/apps/web/dist /srv

# Copy Caddyfile
COPY Caddyfile /etc/caddy/Caddyfile

EXPOSE 8080
