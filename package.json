{
  "name": "passmgr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:up": "turbo run db:up",
    "db:generate": "pnpm run --filter @repo/db db:generate",
    "db:migrate": "pnpm run --filter @repo/db db:migrate",
    "db:seed": "pnpm run --filter @repo/db db:seed",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:fix-selected": "pnpm run format -- --ignore-unknown",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "turbo run test:integration",
    "test:integration:coverage": "turbo run test:integration:coverage",
    "e2e": "turbo run e2e",
    "e2e:ui": "turbo run e2e:ui",
    "typegen:css": "turbo run typegen:css",
    "storybook": "turbo run storybook",
    "build:storybook": "turbo run build:storybook",
    "stryker:crypto": "stryker run stryker.crypto.config.mjs",
    "stryker:store": "stryker run stryker.store.config.mjs",
    "stryker:server-auth": "stryker run stryker.server-auth.config.mjs",
    "stryker:client": "stryker run stryker.client.config.mjs",
    "fallow": "fallow"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@prettier/plugin-oxc": "^0.1.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "fallow": "^2.76.0",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "fallow",
      "protobufjs",
      "sharp",
      "ssh2"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "zod": "^4.4.3",
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    }
  }
}
