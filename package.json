{
  "name": "passmgr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:up": "turbo run db:up",
    "db:generate": "pnpm run --filter @repo/db db:generate",
    "db:migrate": "pnpm run --filter @repo/db db:migrate",
    "db:seed": "pnpm run --filter @repo/db db:seed",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:fix-selected": "pnpm run format -- --ignore-unknown",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "e2e": "turbo run e2e",
    "e2e:ui": "turbo run e2e:ui",
    "typegen:css": "turbo run typegen:css",
    "storybook": "turbo run storybook",
    "build:storybook": "turbo run build:storybook",
    "fallow": "fallow"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@prettier/plugin-oxc": "^0.1.4",
    "fallow": "^2.63.0",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "zod": "^4.4.3"
    }
  }
}
