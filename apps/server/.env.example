REDIS_HOST=localhost
REDIS_PORT=6379
REGISTRATION_DISABLED=
PREFIX=/trpc

# OPAQUE (cloudflare opaque-ts). Generate with:
#   bun apps/server/scripts/opaque-cf-bootstrap.ts
OPAQUE_OPRF_SEED=
OPAQUE_AKE_PRIVATE_KEY=
OPAQUE_SERVER_IDENTITY=passmgr
# Legacy: still used as the HMAC/encryption key for email hashing & email-at-rest.
OPAQUE_SERVER_SETUP=

# Production: allowed CORS origin (e.g. https://pass.example.com)
CORS_ORIGIN=

# Log level: trace|debug|info|warn|error|fatal (default: info in prod, debug in dev)
LOG_LEVEL=
