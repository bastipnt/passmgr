# PostgreSQL
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
POSTGRES_DB=passmgr

# OPAQUE server setup key (base64-encoded)
# Generate with: bunx @serenity-kit/opaque create-server-setup
OPAQUE_SERVER_SETUP=

# CORS origin (your production domain, including protocol)
CORS_ORIGIN=https://pass.example.com

# Disable public registration (set to "true" or leave empty)
REGISTRATION_DISABLED=true

# Port exposed on the host (your external Caddy points here)
WEB_PORT=8080
