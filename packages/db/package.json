{
  "name": "@repo/db",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --type-aware",
    "db:up": "docker compose up",
    "db:dev": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:push": "npx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:reset": "bun ./devResetDB.ts",
    "db:seed": "bun ./devSeed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@repo/crypto": "workspace:*",
    "@repo/schema": "workspace:*",
    "@repo/util": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "catalog:",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "catalog:",
    "oxlint": "catalog:",
    "pg": "^8.21.0",
    "testcontainers": "catalog:",
    "tsx": "^4.22.4",
    "vitest": "catalog:"
  }
}
