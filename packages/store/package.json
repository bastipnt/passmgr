{
  "name": "@repo/store",
  "version": "0.0.1",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./drivers/web": "./src/drivers/web.ts",
    "./drivers/native": "./src/drivers/native.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@repo/crypto": "workspace:*",
    "@repo/schema": "workspace:*",
    "@repo/util": "workspace:*"
  },
  "peerDependencies": {
    "expo-secure-store": "*",
    "expo-sqlite": "*",
    "sqlocal": "*"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "sqlocal": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
